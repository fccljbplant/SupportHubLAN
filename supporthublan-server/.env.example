# SupportHubLAN Backend Configuration
# Copy this file to ".env" (no quotes) and edit values as needed.

# Port the backend listens on (frontend is served from the same port)
PORT=8080

# Path to PsTools folder (must contain psexec.exe, psinfo.exe, etc.)
PSTOOLS_PATH=C:\\PSTools\\

# Bind address — use 127.0.0.1 to restrict to localhost only, 0.0.0.0 for LAN access
BIND_ADDRESS=0.0.0.0

# Optional Basic Auth (leave blank to disable — recommended for VPN-only access)
ADMIN_USER=
ADMIN_PASS=

# CORS allowed origins (comma-separated, or * for any)
ALLOWED_ORIGINS=*

# Auto-open browser on startup (Windows only)
AUTO_OPEN_BROWSER=true
