function doMoveDivider( divider, event )
{
	dx    = 0; 
	event ? ( event.onmousedown = doMoveMouseDown ) : ( divider.onmousedown = doMoveMouseDown );
	function doMoveMouseDown( e )
	{
		dx                   = e.clientX;
		document.onmousemove = onMouseMove;
		document.onmouseup   = onMouseUp;
	}
	function onMouseMove( e )
	{
		const xPos              = e.clientX;
		const bookmarks       = document.getElementById( "bookmarksid" );
		const body            = document.getElementById( "bodyid" );
		let bookmarksWidth    = bookmarks.offsetWidth + ( xPos - dx );
		bookmarks.style.width = bookmarksWidth + "px";
		divider.style.left    = bookmarksWidth +  5 + "px";
		dx                    = xPos;
	}
	function onMouseUp( e )
	{
		const bookmarks        = document.getElementById( "bookmarksid" );
		const body             = document.getElementById( "bodyid" );
		let bookmarksWidth     = bookmarks.offsetWidth;
		body.style.marginLeft  = bookmarksWidth + 20 + "px";
		document.onmousemove = null;
		document.onmouseup     = null;
	}
}
